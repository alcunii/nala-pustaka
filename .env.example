# Google Gemini API Key
# Dapatkan API key gratis di: https://aistudio.google.com/app/apikey
# Copy file ini menjadi .env dan isi dengan API key Anda
VITE_GEMINI_API_KEY=your_api_key_here

# Supabase (untuk Admin Panel & Database)
# Dapatkan credentials di: https://supabase.com → Project Settings → API
# Project URL dan anon key (public key, aman untuk client-side)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
